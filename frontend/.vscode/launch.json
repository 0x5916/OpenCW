{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Frontend: Dev Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev"
    },
    {
      "name": "Frontend: Dev Server Global",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host 0.0.0.0"
    },
    {
      "name": "Frontend: Production Build + Run",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run build && npm run start"
    }
  ]
}
