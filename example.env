# PostgreSQL
POSTGRES_USER=opencw
POSTGRES_PASSWORD=
POSTGRES_DB=opencw
DB_PORT=5432

# Backend
# JWT secret must be base64-encoded bytes (≥ 32 raw bytes recommended).
# Generate with: openssl rand -base64 32
JWT_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=OpenCW <no-reply@example.com>

# Comma-separated list of origins the browser is allowed to call the API from.
CORS_ORIGINS=http://localhost:3000,https://www.opencw.net,https://opencw.net

# Backend runtime tuning
READ_TIMEOUT=15s
READ_HEADER_TIMEOUT=5s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=120s
SHUTDOWN_TIMEOUT=20s

# Backend DB pool tuning
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# Cloudflare Tunnel (optional profile in docker compose)
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_PROTOCOL=quic

# Frontend (build-time)
# URL the *browser* uses to reach the backend API.
# For local access with the default port mappings:
PUBLIC_API_BASE=https://api.opencw.net/v1
