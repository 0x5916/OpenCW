# This environment file is for development use only.
PORT=8080
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=secret
DB_NAME=opencw

# Generate token by: openssl rand -base64 32
JWT_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=OpenCW <onboarding@resend.dev>

GIN_MODE=debug

# Optional CORS allowlist for production, comma-separated
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# HTTP server tuning (Go time.Duration format)
READ_TIMEOUT=15s
READ_HEADER_TIMEOUT=5s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=120s
SHUTDOWN_TIMEOUT=20s

# DB pool tuning
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
