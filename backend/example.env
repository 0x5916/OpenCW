PORT=8080
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=secret
DB_NAME=opencw

# Generate token by: openssl rand -base64 32
JWT_SECRET=your-dev-secret-here

GIN_MODE=debug

# Comma-separated list of allowed CORS origins.
# When set, this takes priority over GIN_MODE-based logic.
# Example for local frontend dev: CORS_ORIGINS=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
